{
  "name": "addshore/psr-6-mediawiki-bagostuff-adapter",
  "type": "library",
  "description": "A MediaWiki BagOStuff PSR-6 adapter library",
  "keywords": ["Mediawiki", "Cache"],
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Addshore"
    }
  ],
  "require": {
    "psr/cache": "^3.0",
    "php": "^8.2"
  },
  "require-dev": {
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "mediawiki/mediawiki-codesniffer": "47.0",
    "phpunit/phpunit": "^11.5"
  },
  "scripts": {
    "lint": "parallel-lint . --exclude vendor",
    "sniff": "phpcs -ps --runtime-set installed_paths vendor/mediawiki/mediawiki-codesniffer,vendor/phpcsstandards/phpcsextra",
    "phpunit": "phpunit -c phpunit.xml.dist",
    "test": [
      "@lint",
      "@sniff",
      "@phpunit"
    ],
    "ci": [
      "@lint",
      "@sniff",
      "@phpunit"
    ]
  },
  "autoload": {
    "psr-4": {
      "Addshore\\Psr\\Cache\\MWBagOStuffAdapter\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Addshore\\Psr\\Cache\\MWBagOStuffAdapter\\Tests\\": "tests/unit/",
      "Wikimedia\\ObjectCache\\": "tests/stubs/ObjectCache/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
